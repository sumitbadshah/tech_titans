{
  "manifest_version": 3,
  "name": "ImpulseGuard",
  "version": "2.0.0",
  "description": "Stop impulse buying - Get a mindful reminder when you're about to checkout. Syncs with your personal dashboard.",
  "permissions": ["storage", "activeTab", "tabs", "alarms"],
  "host_permissions": [
    "https://www.amazon.com/*",
    "https://www.amazon.in/*",
    "https://www.flipkart.com/*",
    "https://www.myntra.com/*",
    "https://www.meesho.com/*",
    "http://localhost:3000/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.amazon.com/*",
        "https://www.amazon.in/*",
        "https://www.flipkart.com/*",
        "https://www.myntra.com/*",
        "https://www.meesho.com/*"
      ],
      "js": ["src/content.js"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}